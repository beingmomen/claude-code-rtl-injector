{
  "name": "ai-extensions-rtl-support",
  "displayName": "AI Extensions RTL Support",
  "description": "Automatically injects RTL/Arabic CSS into AI extension webviews (Claude Code, Codex, Copilot Chat) for proper Arabic text rendering",
  "version": "0.8.0",
  "publisher": "beingmomen",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/beingmomen/claude-code-rtl-injector"
  },
  "homepage": "https://github.com/beingmomen/claude-code-rtl-injector#readme",
  "bugs": {
    "url": "https://github.com/beingmomen/claude-code-rtl-injector/issues"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "rtl",
    "arabic",
    "right-to-left",
    "claude",
    "claude-code",
    "codex",
    "openai",
    "chatgpt",
    "bidirectional",
    "bidi",
    "copilot",
    "copilot-chat",
    "github-copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiRtl.inject",
        "title": "AI Extensions RTL: Inject CSS Now"
      },
      {
        "command": "aiRtl.remove",
        "title": "AI Extensions RTL: Remove Injected CSS"
      },
      {
        "command": "aiRtl.status",
        "title": "AI Extensions RTL: Check Status"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "mocha": "^10.7.0",
    "typescript": "^5.5.0"
  }
}